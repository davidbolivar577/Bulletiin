rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. USERS COLLECTION
    match /users/{userId} {
      // Any logged-in user can view profiles
      allow read: if request.auth != null;
      // You can only create/edit your own user document
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // THE CLOUD KEYRING
      // Users have absolute control over their own keys, but no one else can read them.
      match /keys/{keyId} {
      	allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 2. CHANNELS COLLECTION
    match /channels/{channelId} {
      // READ: Anyone logged in can read the list to see the room names (Previews are encrypted!)
      allow read: if request.auth != null;
      
      // CREATE: Any logged-in user can create a brand new channel
      allow create: if request.auth != null;
      
      // UPDATE: (SECURITY FIX) 
      // Users can only bump the channel to the top of the list and update the preview.
      // They cannot change the room name, owner, or public/private status!
      allow update: if request.auth != null &&
                    request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['last_message_at', 'last_message_preview']);
      
      // DELETE: ONLY the person who created the room can delete it!
      allow delete: if request.auth != null && request.auth.uid == resource.data.creator;
    }

    // 3. MESSAGES SUBCOLLECTION
    match /channels/{channelId}/messages/{messageId} {
      
      // HELPER: Grabs the parent channel 
      function getChannel() {
        return get(/databases/$(database)/documents/channels/$(channelId)).data;
      }
      
      // HELPER: Checks if the user has this channel's key in their personal Keyring
      function hasKey() {
      	return exists(/databases/$(database)/documents/users/$(request.auth.uid)/keys/$(channelId));
      }

      // READ: Allowed if the parent channel is public OR you have the key in your keyring
      allow read: if request.auth != null && 
                  (getChannel().isPublic == true || hasKey());
      
      // CREATE: Allowed if channel is public OR you have the key (and no spoofing UIDs)
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.uid
                    && (getChannel().isPublic == true || hasKey());
      
      // UPDATE: To edit or soft-delete a message, you MUST be the original author
      allow update: if request.auth != null && request.auth.uid == resource.data.uid;
                    
      // DELETE: Hard deletes limited to the original author
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }
  }
}